{
  "name": "Youtube-For-Gamepad",
  "version": "2.0.3",
  "description": "YouTube Desktop App with Controller Support",
  "main": "main.js",
  "author": "You",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --publish never",
    "build:win": "electron-builder --win portable --publish never",
    "build:linux": "electron-builder --linux AppImage --publish never"
  },
  "devDependencies": {
    "electron": "^37.0.0",
    "electron-builder": "^26.0.0"
  },
  "build": {
    "appId": "com.youtube.tvapp",
    "productName": "YouTube TV",
    "win": {
      "target": "portable",
      "icon": "assets/icon.ico"
    },
    "linux": {
      "target": "AppImage",
      "category": "AudioVideo"
    }
  }
}